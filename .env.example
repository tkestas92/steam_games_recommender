# Duomenų bazė - PostgreSQL
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/steam_db
# Arba naudok šiuos žemiau:
DB_USER=steam_user
DB_HOST=localhost
DB_PORT=5432
DB_NAME=steam_db

# Modelių aplankas
MODEL_DIR=./models

# Google Gemini API raktas (iš Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Flask sesijos šifravimo raktas (atsitiktinis 32 byte string)
SECRET_KEY=your_secret_key_here_min_32_chars_long

# Logging
LOG_LEVEL=INFO
